#!/usr/bin/env python3

import argparse
import json
import os
import shlex
import shutil
import subprocess
from pathlib import Path


DEFAULT_CONFIG = {
    "mode": "ask",
    "blockOnAutoRoute": True,
    "launchStrategy": "capture",
    "copilotModel": "gpt-5.4",
    "minPromptLength": 24,
}

TERMINALS = [
    ("kgx", lambda shell: ["kgx", "bash", "-lc", shell]),
    ("gnome-terminal", lambda shell: ["gnome-terminal", "--", "bash", "-lc", shell]),
    ("konsole", lambda shell: ["konsole", "-e", "bash", "-lc", shell]),
    ("xfce4-terminal", lambda shell: ["xfce4-terminal", "--command", f"bash -lc {shlex.quote(shell)}"]),
    ("kitty", lambda shell: ["kitty", "bash", "-lc", shell]),
    ("wezterm", lambda shell: ["wezterm", "start", "--", "bash", "-lc", shell]),
    ("alacritty", lambda shell: ["alacritty", "-e", "bash", "-lc", shell]),
    ("xterm", lambda shell: ["xterm", "-e", "bash", "-lc", shell]),
]


def project_dir() -> Path:
    value = os.environ.get("CLAUDE_PROJECT_DIR") or os.getcwd()
    return Path(value).resolve()


def user_claude_dir() -> Path:
    return Path.home() / ".claude"


def load_config(root: Path) -> dict:
    config = dict(DEFAULT_CONFIG)
    project_config = root / ".claude" / "copilot-router.json"
    user_config = user_claude_dir() / "copilot-router.json"
    config_path = project_config if project_config.exists() else user_config
    if config_path.exists():
        config.update(json.loads(config_path.read_text()))
    return config


def read_prompt(args: argparse.Namespace) -> str:
    if args.stdin_prompt:
        prompt = input() if os.isatty(0) else os.sys.stdin.read()
    elif args.prompt:
        prompt = args.prompt
    else:
        raise SystemExit("Provide --prompt or --stdin-prompt.")
    prompt = prompt.strip()
    if not prompt:
        raise SystemExit("Prompt is empty.")
    return prompt


def wrap_prompt(prompt: str) -> str:
    return (
        "You are handling a delegated subtask from Claude Code.\n"
        "Stay scoped to exploration, debugging, review, or investigation work unless the prompt explicitly asks for edits.\n"
        "Work silently. Do not narrate your process, thinking, or intermediate steps.\n"
        "Return only the final result, in at most 5 short bullets or a short paragraph.\n"
        "Include only findings, likely root cause if relevant, affected files or commands, and next steps.\n\n"
        f"Delegated task:\n{prompt}"
    )


def copilot_command(root: Path, prompt: str, config: dict) -> list[str]:
    command = ["copilot", "--add-dir", str(root)]
    model = str(config.get("copilotModel", "")).strip()
    if model:
        command.extend(["--model", model])
    command.extend(["-i", wrap_prompt(prompt)])
    return command


def terminal_command(copilot_args: list[str], root: Path) -> list[str] | None:
    if not (os.environ.get("DISPLAY") or os.environ.get("WAYLAND_DISPLAY")):
        return None

    shell = (
        f"cd {shlex.quote(str(root))} && "
        f"{shlex.join(copilot_args)}; "
        "printf '\\n[Copilot subtask finished] Press Enter to close...'; "
        "read _"
    )
    for name, builder in TERMINALS:
        if shutil.which(name):
            return builder(shell)
    return None


def main() -> int:
    parser = argparse.ArgumentParser(description="Launch a delegated Copilot subtask.")
    parser.add_argument("--prompt", help="Prompt text for Copilot.")
    parser.add_argument("--stdin-prompt", action="store_true", help="Read prompt text from stdin.")
    parser.add_argument("--dry-run", action="store_true", help="Print the chosen launch command without executing it.")
    parser.add_argument("--inline", action="store_true", help="Run Copilot in the current terminal.")
    parser.add_argument("--capture-result", action="store_true", help="Run Copilot non-interactively and print only the final result.")
    args = parser.parse_args()

    root = project_dir()
    config = load_config(root)
    prompt = read_prompt(args)
    copilot_args = copilot_command(root, prompt, config)

    if args.capture_result:
        capture_args = copilot_args[:]
        prompt_text = capture_args.pop()
        capture_args[-1] = "-p"
        capture_args.extend(
            [
                prompt_text,
                "--allow-all",
                "--no-custom-instructions",
                "--stream",
                "off",
                "--output-format",
                "text",
                "--silent",
            ]
        )
        if args.dry_run:
            print(json.dumps({"cwd": str(root), "copilot_args": capture_args}, indent=2))
            return 0
        os.chdir(root)
        return subprocess.call(capture_args)

    terminal_args = None if args.inline else terminal_command(copilot_args, root)
    if args.dry_run:
        print(json.dumps({"cwd": str(root), "copilot_args": copilot_args, "terminal_args": terminal_args}, indent=2))
        return 0

    if terminal_args:
        subprocess.Popen(terminal_args, cwd=root)
        print(f"Launched Copilot in a new terminal from {root}.")
        return 0

    os.chdir(root)
    return subprocess.call(copilot_args)


if __name__ == "__main__":
    raise SystemExit(main())
