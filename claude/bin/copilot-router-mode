#!/usr/bin/env python3

import json
import os
import sys
from pathlib import Path


VALID_MODES = {"off", "ask", "on"}


def config_path() -> Path:
    root = Path(os.environ.get("CLAUDE_PROJECT_DIR") or os.getcwd()).resolve()
    project_config = root / ".claude" / "copilot-router.json"
    if project_config.exists():
        return project_config
    return Path.home() / ".claude" / "copilot-router.json"


def load_config(path: Path) -> dict:
    if path.exists():
        return json.loads(path.read_text())
    return {
        "mode": "ask",
        "blockOnAutoRoute": True,
        "launchStrategy": "capture",
        "copilotModel": "gpt-5.4",
        "minPromptLength": 24,
    }


def save_config(path: Path, config: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(config, indent=2) + "\n")


def main() -> int:
    path = config_path()
    config = load_config(path)

    if len(sys.argv) == 1 or sys.argv[1] == "status":
        print(f"mode={config.get('mode', 'ask')} ({path})")
        return 0

    mode = sys.argv[1].lower()
    if mode not in VALID_MODES:
        print("Usage: copilot-router-mode [status|off|ask|on]", file=sys.stderr)
        return 1

    config["mode"] = mode
    save_config(path, config)
    print(f"mode={mode} ({path})")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
